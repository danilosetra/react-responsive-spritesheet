{
  "name": "react-responsive-spritesheet",
  "description": "React component which helps you to easily apply responsive spritesheet animations on your project.",
  "version": "2.4.0",
  "license": "MIT",
  "homepage": "https://github.com/danilosetra/react-responsive-spritesheet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danilosetra/react-responsive-spritesheet.git"
  },
  "bugs": {
    "url": "https://github.com/danilosetra/react-responsive-spritesheet/issues"
  },
  "keywords": [
    "react",
    "reactjs",
    "responsive",
    "responsiveness",
    "component",
    "module",
    "sprite",
    "sprites",
    "spritesheet",
    "animated",
    "animation",
    "sequence"
  ],
  "main": "build/index.js",
  "types": "build/js/index.d.ts",
  "author": {
    "name": "Danilo Setra",
    "email": "danilosetra@gmail.com"
  },
  "scripts": {
    "start": "webpack --watch",
    "build": "webpack && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "build-pub": "bash publish.sh",
    "lintjs-local": "eslint --ext .ts,.tsx,.js,.jsx src demo",
    "format": "prettier --single-quote --trailing-comma none --print-width 120 --write \"src/js/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --single-quote --trailing-comma none --print-width 120 --check \"src/js/**/*.{ts,tsx,js,jsx}\"",
    "dev": "webpack serve --config webpack.dev.js"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-object-rest-spread": "^7.28.4",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/plugin-transform-private-property-in-object": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.0.0",
    "babel-preset-minify": "^0.5.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "html-webpack-plugin": "^5.6.3",
    "prettier": "^3.7.4",
    "random-id": "1.0.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "terser-webpack-plugin": "^5.3.15",
    "typescript": "^5.9.3",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.0.4"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
